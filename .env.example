DATABASE_URL="postgresql://user:password@localhost:5432/sundaftrip"
# Optional Prisma pool tuning for hosted Postgres.
PRISMA_CONNECTION_LIMIT=""
PRISMA_POOL_TIMEOUT=""
# Production deploy DB guard. Set "true" only for an approved deploy that may run prisma db push + seed.
ALLOW_PRODUCTION_DB_MIGRATION=""

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Auth.js v5 aliases used by some server utilities.
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Sundaf Trip"
# NextAuth v5 di belakang proxy (Vercel) — set "true"
AUTH_TRUST_HOST="true"

# Referral MVP
# Kosongkan untuk fallback ke setting CMS company_whatsapp.
SUNDAF_WHATSAPP_NUMBER=""

# Seed admin pertama (WAJIB di production — tanpa ini seed skip pembuatan admin)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME=""
SEED_THEME=""
SEED_COMPANY_NAME=""

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER=""

# Scraper Konten
ANTHROPIC_API_KEY=""
PEXELS_API_KEY=""
# Facebook: copy cookie c_user dan xs dari browser DevTools
FACEBOOK_COOKIE=""
# Cron job secret (buat sendiri, isi bebas, contoh: openssl rand -hex 32)
CRON_SECRET=""

# ── Plan ──
# Plan deployment ini. Isi "pro" atau "basic". Default "basic" kalau kosong.
NEXT_PUBLIC_PLAN="pro"

# Analytics, optional.
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_FB_PIXEL_ID=""

# Local maintenance scripts only.
RESET_PASSWORD=""
