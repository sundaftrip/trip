NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Scraper Konten
GROQ_API_KEY=""
# Facebook: copy cookie c_user dan xs dari browser DevTools
FACEBOOK_COOKIE=""
# Cron job secret (buat sendiri, isi bebas, contoh: openssl rand -hex 32)
CRON_SECRET=""

# Password untuk reset SELURUH data modul keuangan (Zona Berbahaya).
# Hanya SUPERADMIN yang tahu password ini yang bisa mereset. Kalau
# kosong, fitur reset dinonaktifkan.
KEUANGAN_RESET_SECRET=""

# ── Lisensi / Plan (dikelola panel SUNDAF/MASTER) ──
# apiKey unik deployment ini — didapat dari panel MASTER saat Client dibuat.
# Dipakai untuk: (1) otentikasi panggilan MASTER -> deployment ini,
#                (2) identifikasi deployment ini saat fetch plan ke MASTER.
MASTER_API_KEY=""
# URL deployment panel MASTER, mis. https://sundaf-master.vercel.app
MASTER_API_URL=""
# Fallback plan kalau deployment TIDAK dikelola MASTER (MASTER_API_URL kosong).
# Isi "pro" atau "basic". Diabaikan kalau MASTER_API_URL terisi.
NEXT_PUBLIC_PLAN="basic"
