DATABASE_URL="postgresql://user:password@localhost:5432/sundaftrip"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# NextAuth v5 di belakang proxy (Vercel) — set "true"
AUTH_TRUST_HOST="true"

# Seed admin pertama (WAJIB di production — tanpa ini seed skip pembuatan admin)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME=""

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Scraper Konten
GROQ_API_KEY=""
ANTHROPIC_API_KEY=""
PEXELS_API_KEY=""
# Facebook: copy cookie c_user dan xs dari browser DevTools
FACEBOOK_COOKIE=""
# Cron job secret (buat sendiri, isi bebas, contoh: openssl rand -hex 32)
CRON_SECRET=""

# ── Plan ──
# Plan deployment ini. Isi "pro" atau "basic". Default "basic" kalau kosong.
NEXT_PUBLIC_PLAN="pro"
