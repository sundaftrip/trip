generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  EDITOR
}

enum TourStatus {
  ACTIVE
  DRAFT
  FULL
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(EDITOR)
  permissions   Json?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  receipts      Receipt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tour {
  id             String     @id @default(cuid())
  title          String
  country        String
  cityHighlight  String?
  price          Float
  promoPrice     Float?
  priceLandTour  Float?
  seatsLeft      Int        @default(0)
  status         TourStatus @default(DRAFT)
  tripDate       DateTime?
  duration       String?
  itinerary      Json?
  inclusions     String[]
  exclusions     String[]
  gallery        String[]
  hotel          Json?
  visaInfo       String?
  heroImg        String?
  badge          String?
  notes          String?
  description    String?
  addOns         Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  receipts       Receipt[]
  finance        TripFinance?
  vendorBills    VendorBill[]
  ledgerEntries  LedgerEntry[]
}

model Blog {
  id             String          @id @default(cuid())
  slug           String          @unique
  title          String
  excerpt        String?
  cover          String?
  category       String?
  date           DateTime        @default(now())
  author         String?
  body           String?
  readTime       String?
  published      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scrapedContent ScrapedContent?
}

model ScrapedContent {
  id             String   @id @default(cuid())
  sourceUrl      String   @unique
  sourcePlatform String
  subreddit      String?
  originalTitle  String
  originalBody   String
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  blog           Blog?    @relation(fields: [blogId], references: [id])
  blogId         String?  @unique
}

model SiteText {
  id        String   @id @default(cuid())
  key       String   @unique
  valueId   String?
  valueEn   String?
  updatedAt DateTime @updatedAt
}

model Receipt {
  id           String   @id @default(cuid())
  receiptNo    String   @unique
  customerName String
  customerPhone String?
  customerEmail String?
  tourId       String?
  tourTitle    String
  tripDate     String?
  pax          Int      @default(1)
  amount       Float
  paymentMethod String?
  paymentDate  DateTime?
  notes        String?
  status       String   @default("UNPAID")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tour         Tour?    @relation(fields: [tourId], references: [id])
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdById  String?
}

model TermsCondition {
  id        String   @id @default(cuid())
  bodyId    String?
  bodyEn    String?
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  section   String   // e.g. "Umum", "Visa & Dokumen"
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyInfo {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model RolePermission {
  id          String   @id @default(cuid())
  role        String   @unique
  permissions Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id           String   @id @default(cuid())
  userId       String
  userName     String
  userRole     String
  action       String
  resource     String
  resourceId   String?
  resourceName String?
  detail       String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String
  rating    Int      @default(5)
  avatar    String?
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
//  MODUL KEUANGAN  —  real-time accounting untuk perusahaan travel
//  Tabel baru, tidak menyentuh model website yang sudah ada.
// ─────────────────────────────────────────────────────────────

enum AccountKind {
  BANK
  CASH
  EWALLET
}

enum EntryDirection {
  IN
  OUT
}

// Asal sebuah baris jurnal — dipakai untuk klasifikasi akuntansi.
enum EntrySource {
  MANUAL          // entry manual non-trip
  PESERTA         // pelunasan / DP peserta (cash in)
  VENDOR_PAYMENT  // bayar tagihan vendor (pelunasan hutang, BUKAN beban)
  DEPOSIT         // deposit PNR / titipan ke maskapai
  OPERATIONAL     // biaya operasional kantor (beban P&L)
  REFUND          // pengembalian dana
  CAPITAL         // setoran modal pemilik (menambah ekuitas, BUKAN pendapatan)
  PRIVE           // penarikan pemilik (mengurangi ekuitas, BUKAN beban)
  OTHER
}

enum VendorCategory {
  AIRLINE
  HOTEL
  LAND_OPERATOR
  VISA
  TRANSPORT
  INSURANCE
  GUIDE
  OTHER
}

enum BillStatus {
  UNPAID
  PARTIAL
  PAID
}

enum TripFinanceStatus {
  DRAFT      // proyeksi belum dikunci Finance
  CONFIRMED  // proyeksi sudah dikunci → margin bisa dihitung
}

// Rekening bank / kas / e-wallet perusahaan.
model BankAccount {
  id             String        @id @default(cuid())
  name           String
  kind           AccountKind   @default(BANK)
  accountNo      String?
  openingBalance Float         @default(0)
  note           String?
  archived       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  entries        LedgerEntry[]
}

// Mitra vendor: maskapai, hotel, land operator, dll.
model Vendor {
  id        String         @id @default(cuid())
  name      String
  category  VendorCategory @default(OTHER)
  contact   String?
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  bills     VendorBill[]
}

// Tagihan vendor (hutang). amountPaid dilunasi lewat LedgerEntry OUT.
model VendorBill {
  id          String        @id @default(cuid())
  vendorId    String
  vendor      Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  tourId      String?
  tour        Tour?         @relation(fields: [tourId], references: [id])
  description String
  amount      Float                        // SELALU dalam IDR (mata uang fungsional)
  amountPaid  Float         @default(0)     // IDR
  currency    String        @default("IDR") // mata uang asli tagihan: IDR/USD/RUB/EUR/SGD
  fxRate      Float         @default(1)      // kurs ke IDR saat tagihan dibuat (amount = nominalAsing * fxRate)
  status      BillStatus    @default(UNPAID)
  isDeposit   Boolean       @default(false) // true = deposit PNR / titipan maskapai
  dueDate     DateTime?
  voided      Boolean       @default(false) // dibatalkan — tidak ikut perhitungan, tetap tersimpan
  voidedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payments    LedgerEntry[]

  @@index([tourId])
  @@index([vendorId])
}

// Proyeksi keuangan per trip — di-input tim Finance.
model TripFinance {
  id           String            @id @default(cuid())
  tourId       String            @unique
  tour         Tour              @relation(fields: [tourId], references: [id], onDelete: Cascade)
  sellingPrice Float             @default(0) // harga jual per pax
  targetPax    Int               @default(0)
  projHpp      Float             @default(0) // HPP proyeksi total
  status       TripFinanceStatus @default(DRAFT)
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

// Buku besar kas — setiap pergerakan uang masuk/keluar.
model LedgerEntry {
  id            String         @id @default(cuid())
  date          DateTime       @default(now())
  direction     EntryDirection
  amount        Float
  category      String
  description   String?
  source        EntrySource    @default(MANUAL)
  bankAccountId String?
  bankAccount   BankAccount?   @relation(fields: [bankAccountId], references: [id])
  tourId        String?
  tour          Tour?          @relation(fields: [tourId], references: [id])
  vendorBillId  String?
  vendorBill    VendorBill?    @relation(fields: [vendorBillId], references: [id])
  createdById   String?
  voided        Boolean        @default(false) // dibatalkan via jurnal balik — tetap tersimpan utk jejak audit
  voidedAt      DateTime?
  createdAt     DateTime       @default(now())

  @@index([date])
  @@index([tourId])
  @@index([direction])
}
