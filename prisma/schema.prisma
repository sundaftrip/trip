generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  EDITOR
}

enum TourStatus {
  ACTIVE
  DRAFT
  FULL
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(EDITOR)
  permissions   Json?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  receipts      Receipt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tour {
  id             String     @id @default(cuid())
  title          String
  slug           String?    @unique // URL rapi: /tours/<slug>; null → fallback ke id
  country        String
  cityHighlight  String?
  price          Float
  promoPrice     Float?
  priceLandTour  Float?
  seatsLeft      Int        @default(0)
  status         TourStatus @default(DRAFT)
  tripDate       DateTime?
  duration       String?
  itinerary      Json?
  inclusions     String[]
  exclusions     String[]
  gallery        String[]
  hotel          Json?
  visaInfo       String?
  heroImg        String?
  badge          String?
  notes          String?
  description    String?
  addOns         Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  receipts       Receipt[]
  finance        TripFinance?
  vendorBills    VendorBill[]
  ledgerEntries  LedgerEntry[]
  fieldExpenses  FieldExpense[]
  testimonials   Testimonial[]
  expenseToken   String?    @unique  // token link pelaporan pengeluaran TL

  // Index untuk query publik yang sering: filter status/negara & sort tanggal trip
  @@index([status])
  @@index([country])
  @@index([tripDate])
}

model Blog {
  id             String          @id @default(cuid())
  slug           String          @unique
  title          String
  excerpt        String?
  cover          String?
  category       String?
  date           DateTime        @default(now())
  author         String?
  body           String?
  readTime       String?
  published      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scrapedContent ScrapedContent?
}

model GeoPage {
  id                String   @id @default(cuid())
  routePath         String   @unique
  title             String
  eyebrow           String?
  metaTitle         String?
  metaDescription   String?  @db.Text
  answer            String   @db.Text
  primaryCtaLabel   String?
  primaryCtaHref    String?
  secondaryCtaLabel String?
  secondaryCtaHref  String?
  sections          Json?
  faqs              Json?
  schemaType        String   @default("WebPage")
  published         Boolean  @default(true)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([published, order])
}

model ScrapedContent {
  id             String   @id @default(cuid())
  sourceUrl      String   @unique
  sourcePlatform String
  subreddit      String?
  originalTitle  String
  originalBody   String
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  blog           Blog?    @relation(fields: [blogId], references: [id])
  blogId         String?  @unique
}

model SiteText {
  id        String   @id @default(cuid())
  key       String   @unique
  valueId   String?
  valueEn   String?
  updatedAt DateTime @updatedAt
}

model Receipt {
  id           String   @id @default(cuid())
  receiptNo    String   @unique
  customerName String
  customerPhone String?
  customerEmail String?
  tourId       String?
  tourTitle    String
  tripDate     String?
  pax          Int      @default(1)
  amount       Float
  paymentMethod String?
  paymentDate  DateTime?
  notes        String?
  status       String   @default("UNPAID")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tour         Tour?    @relation(fields: [tourId], references: [id])
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdById  String?
}

model TermsCondition {
  id        String   @id @default(cuid())
  bodyId    String?
  bodyEn    String?
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  group     String   @default("umum") // "umum" (/faq) atau "visa" (/visa/faq)
  section   String   // e.g. "Umum", "Visa & Dokumen"
  question  String
  answer    String   @db.Text // HTML
  service   String?  @db.Text // CTA layanan per item (visa): null=default, "__NONE__"=tanpa CTA, lainnya=teks custom
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group, section, order])
}

model CompanyInfo {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model RolePermission {
  id          String   @id @default(cuid())
  role        String   @unique
  permissions Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id           String   @id @default(cuid())
  userId       String
  userName     String
  userRole     String
  action       String
  resource     String
  resourceId   String?
  resourceName String?
  detail       String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String
  rating    Int      @default(5)
  avatar    String?
  category  String   @default("trip") // "trip" | "visa" — pisahkan ulasan trip rombongan vs layanan visa
  published Boolean  @default(true)
  order     Int      @default(0)
  tourId    String?  // ulasan ini untuk tour spesifik (opsional) — dasar aggregateRating per-tour
  tour      Tour?    @relation(fields: [tourId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tourId])
}

// ─────────────────────────────────────────────────────────────
//  MODUL KEUANGAN  —  real-time accounting untuk perusahaan travel
//  Tabel baru, tidak menyentuh model website yang sudah ada.
// ─────────────────────────────────────────────────────────────

enum AccountKind {
  BANK
  CASH
  EWALLET
}

enum EntryDirection {
  IN
  OUT
}

// Asal sebuah baris jurnal — dipakai untuk klasifikasi akuntansi.
enum EntrySource {
  MANUAL          // entry manual non-trip
  PESERTA         // pelunasan / DP peserta (cash in)
  VENDOR_PAYMENT  // bayar tagihan vendor (pelunasan hutang, BUKAN beban)
  DEPOSIT         // deposit PNR / titipan ke maskapai
  OPERATIONAL     // biaya operasional kantor (beban P&L)
  REFUND          // pengembalian dana
  CAPITAL         // setoran modal pemilik (menambah ekuitas, BUKAN pendapatan)
  PRIVE           // penarikan pemilik (mengurangi ekuitas, BUKAN beban)
  ADVANCE         // kasbon / uang muka kerja ke TL (aset, BUKAN beban)
  OTHER
}

enum FieldExpenseStatus {
  PENDING   // diajukan TL, menunggu review
  APPROVED  // disetujui — masuk HPP trip
  REJECTED  // ditolak
}

enum VendorCategory {
  AIRLINE
  HOTEL
  LAND_OPERATOR
  VISA
  TRANSPORT
  INSURANCE
  GUIDE
  OTHER
}

enum BillStatus {
  UNPAID
  PARTIAL
  PAID
}

enum TripFinanceStatus {
  DRAFT      // proyeksi belum dikunci Finance
  CONFIRMED  // proyeksi sudah dikunci → margin bisa dihitung
}

// Rekening bank / kas / e-wallet perusahaan.
model BankAccount {
  id             String        @id @default(cuid())
  name           String
  kind           AccountKind   @default(BANK)
  accountNo      String?
  openingBalance Float         @default(0)
  note           String?
  archived       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  entries        LedgerEntry[]
}

// Mitra vendor: maskapai, hotel, land operator, dll.
model Vendor {
  id        String         @id @default(cuid())
  name      String
  category  VendorCategory @default(OTHER)
  contact   String?
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  bills     VendorBill[]
}

// Tagihan vendor (hutang). amountPaid dilunasi lewat LedgerEntry OUT.
model VendorBill {
  id          String        @id @default(cuid())
  vendorId    String
  vendor      Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  tourId      String?
  tour        Tour?         @relation(fields: [tourId], references: [id])
  description String
  amount      Float                        // SELALU dalam IDR (mata uang fungsional)
  amountPaid  Float         @default(0)     // IDR
  currency    String        @default("IDR") // mata uang asli tagihan: IDR/USD/RUB/EUR/SGD
  fxRate      Float         @default(1)      // kurs ke IDR saat tagihan dibuat (amount = nominalAsing * fxRate)
  status      BillStatus    @default(UNPAID)
  isDeposit   Boolean       @default(false) // true = deposit PNR / titipan maskapai
  dueDate     DateTime?
  voided      Boolean       @default(false) // dibatalkan — tidak ikut perhitungan, tetap tersimpan
  voidedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payments    LedgerEntry[]

  @@index([tourId])
  @@index([vendorId])
}

// Proyeksi keuangan per trip — di-input tim Finance.
model TripFinance {
  id           String            @id @default(cuid())
  tourId       String            @unique
  tour         Tour              @relation(fields: [tourId], references: [id], onDelete: Cascade)
  sellingPrice Float             @default(0) // harga jual per pax
  targetPax    Int               @default(0)
  projHpp      Float             @default(0) // HPP proyeksi total
  status       TripFinanceStatus @default(DRAFT)
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

// Pengeluaran lapangan — diajukan TL lewat link bertoken, dengan
// foto bukti. Setelah di-approve jadi bagian HPP trip.
model FieldExpense {
  id          String             @id @default(cuid())
  tourId      String
  tour        Tour               @relation(fields: [tourId], references: [id], onDelete: Cascade)
  date        DateTime
  category    String
  amount      Float
  photoUrl    String             // foto struk/nota — bukti wajib
  note        String?
  submittedBy String             // nama TL
  status      FieldExpenseStatus @default(PENDING)
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([tourId])
  @@index([status])
}

// Buku besar kas — setiap pergerakan uang masuk/keluar.
model LedgerEntry {
  id            String         @id @default(cuid())
  date          DateTime       @default(now())
  direction     EntryDirection
  amount        Float
  category      String
  description   String?
  source        EntrySource    @default(MANUAL)
  bankAccountId String?
  bankAccount   BankAccount?   @relation(fields: [bankAccountId], references: [id])
  tourId        String?
  tour          Tour?          @relation(fields: [tourId], references: [id])
  vendorBillId  String?
  vendorBill    VendorBill?    @relation(fields: [vendorBillId], references: [id])
  createdById   String?
  voided        Boolean        @default(false) // dibatalkan via jurnal balik — tetap tersimpan utk jejak audit
  voidedAt      DateTime?
  createdAt     DateTime       @default(now())

  @@index([date])
  @@index([tourId])
  @@index([direction])
}

// Database visa 88 negara — info persyaratan visa paspor Indonesia.
// Dikelola lewat CMS (/admin/visa-database), tampil di halaman publik /visa.
model CountryVisa {
  id          String   @id @default(cuid())
  sortOrder   Int      @default(0)
  flag        String
  name        String
  en          String
  region      String
  visa        String // "bebas" | "voa" | "evisa" | "wajib"
  stay        String
  cost        String // kosong = ditampilkan "Gratis"
  notes       String
  // Konten kaya per-negara — kosong = fallback ke template per-kategori (lib/visa-defaults.ts).
  eligibility String[] @default([])
  documents   Json     @default("[]") // [{ name: string, hint?: string }]
  faqs        Json     @default("[]") // [{ question: string, answer: string }]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants    VisaVariant[]

  @@index([sortOrder])
}

// Varian layanan visa per-negara — mis. "Single Entry Jakarta",
// "Multiple Entry 6 bulan", dll. Harga sudah termasuk markup Sundaf.
model VisaVariant {
  id              String      @id @default(cuid())
  countryVisaId   String
  countryVisa     CountryVisa @relation(fields: [countryVisaId], references: [id], onDelete: Cascade)
  sortOrder       Int         @default(0)
  name            String
  priceIDR        Int? // null = "tanya harga"
  processingTime  String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([countryVisaId, sortOrder])
}

enum InquiryStatus {
  NEW
  CONTACTED
  CLOSED
}

// Lead dari form konsultasi situs (selain WhatsApp langsung).
model Inquiry {
  id          String        @id @default(cuid())
  name        String
  whatsapp    String
  email       String?
  destination String? // tujuan yang diminati (mis. "Rusia", "Aurora")
  travelDate  String? // teks bebas, mis. "Desember 2026" / "belum tahu"
  message     String?
  source      String? // halaman asal submit (mis. "/tours/abc", "/about")
  status      InquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, createdAt])
}

// Cache terjemahan mesin (ID -> EN) untuk fitur auto-translate situs.
// Sekali sebuah string diterjemahkan, hasilnya dipakai ulang semua pengunjung.
model Translation {
  id        String   @id @default(cuid())
  hash      String   @unique // sha1(source + ":" + target)
  source    String   @db.Text
  target    String   // "en"
  text      String   @db.Text // hasil terjemahan
  createdAt DateTime @default(now())

  @@index([target])
}
