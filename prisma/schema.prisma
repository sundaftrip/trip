generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  EDITOR
}

enum TourStatus {
  ACTIVE
  DRAFT
  FULL
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(EDITOR)
  permissions   Json?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  receipts      Receipt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tour {
  id             String     @id @default(cuid())
  title          String
  country        String
  cityHighlight  String?
  price          Float
  promoPrice     Float?
  priceLandTour  Float?
  seatsLeft      Int        @default(0)
  status         TourStatus @default(DRAFT)
  tripDate       DateTime?
  duration       String?
  itinerary      Json?
  inclusions     String[]
  exclusions     String[]
  gallery        String[]
  hotel          Json?
  visaInfo       String?
  heroImg        String?
  badge          String?
  notes          String?
  description    String?
  addOns         Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  receipts       Receipt[]
}

model Blog {
  id             String          @id @default(cuid())
  slug           String          @unique
  title          String
  excerpt        String?
  cover          String?
  category       String?
  date           DateTime        @default(now())
  author         String?
  body           String?
  readTime       String?
  published      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scrapedContent ScrapedContent?
}

model ScrapedContent {
  id             String   @id @default(cuid())
  sourceUrl      String   @unique
  sourcePlatform String
  subreddit      String?
  originalTitle  String
  originalBody   String
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  blog           Blog?    @relation(fields: [blogId], references: [id])
  blogId         String?  @unique
}

model SiteText {
  id        String   @id @default(cuid())
  key       String   @unique
  valueId   String?
  valueEn   String?
  updatedAt DateTime @updatedAt
}

model Receipt {
  id           String   @id @default(cuid())
  receiptNo    String   @unique
  customerName String
  customerPhone String?
  customerEmail String?
  tourId       String?
  tourTitle    String
  tripDate     String?
  pax          Int      @default(1)
  amount       Float
  paymentMethod String?
  paymentDate  DateTime?
  notes        String?
  status       String   @default("UNPAID")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tour         Tour?    @relation(fields: [tourId], references: [id])
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdById  String?
}

model TermsCondition {
  id        String   @id @default(cuid())
  bodyId    String?
  bodyEn    String?
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  section   String   // e.g. "Umum", "Visa & Dokumen"
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyInfo {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model RolePermission {
  id          String   @id @default(cuid())
  role        String   @unique
  permissions Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id           String   @id @default(cuid())
  userId       String
  userName     String
  userRole     String
  action       String
  resource     String
  resourceId   String?
  resourceName String?
  detail       String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String
  rating    Int      @default(5)
  avatar    String?
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
